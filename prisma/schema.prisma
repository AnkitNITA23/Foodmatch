generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  role      String   @default("RECEIVER") // DONOR or RECEIVER
  lat       Float?   // Latitude
  lng       Float?   // Longitude
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donations       Donation[] @relation("DonatedBy")
  claimedItems    Donation[] @relation("ClaimedBy")
  notifications   Notification[] @relation("UserNotifications")
}

model Donation {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("AVAILABLE") // AVAILABLE, CLAIMED, OUT_FOR_PICKUP, COMPLETED
  pickupPin   String?  // Secure 4-digit PIN for verification
  completedAt DateTime?
  lat         Float
  lng         Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  rating      Int?     // 1 to 5 star rating given by the receiver
  feedback    String?  // Optional text comment from the receiver
  
  donorId     String
  donor       User     @relation("DonatedBy", fields: [donorId], references: [clerkId])
  
  claimerId   String?
  claimer     User?    @relation("ClaimedBy", fields: [claimerId], references: [clerkId])
  
  expiresAt   DateTime? // Optional expiry time after which donation is hidden
}

model Notification {
  id          String   @id @default(cuid())
  message     String
  read        Boolean  @default(false)
  type        String   @default("MATCH") // MATCH, SYSTEM
  createdAt   DateTime @default(now())
  
  userId      String
  user        User     @relation("UserNotifications", fields: [userId], references: [clerkId])
}
